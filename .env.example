# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/zelos

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_NONPROFIT_EIN=

# ─── AWS S3 (file uploads – product images, forum attachments, etc.) ──────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ─── Email (SMTP – transactional emails) ─────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Zelos
# Set to "ssl" for port 465, leave blank for STARTTLS (port 587)
MAIL_ENCRYPTION=

# ─── Stripe (payments & subscriptions) ───────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Captcha (pick one – Cloudflare Turnstile recommended) ───────────────────
# Turnstile
TURNSTILE_SECRET_KEY=
# hCaptcha (fallback)
HCAPTCHA_SECRET_KEY=
# reCAPTCHA v2/v3 (fallback)
RECAPTCHA_SECRET_KEY=
